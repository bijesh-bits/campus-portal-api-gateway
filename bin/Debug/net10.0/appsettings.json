{
  "ReverseProxy": {
    "Routes": {
      "student-route": {
        "ClusterId": "student-cluster",
        "Match": {
          "Path": "/api/students/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/students/{**catch-all}"
          }
        ]
      },
      "course-route": {
        "ClusterId": "course-cluster",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/courses/{**catch-all}"
          }
        ]
      },
      "enrollment-route": {
        "ClusterId": "enrollment-cluster",
        "Match": {
          "Path": "/api/enrollments/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/enrollments/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "student-cluster": {
        "Destinations": {
          "student-destination": {
            "Address": "http://student-service:8080/"
          }
        }
      },
      "course-cluster": {
        "Destinations": {
          "course-destination": {
            "Address": "http://course-service:8080/"
          }
        }
      },
      "enrollment-cluster": {
        "Destinations": {
          "enrollment-destination": {
            "Address": "http://enrollment-service:8080/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
